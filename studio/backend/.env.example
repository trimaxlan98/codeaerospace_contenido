# ManimStudio — copiar a .env y completar. NUNCA commitear el .env real.
MS_ADMIN_USER=admin
# Generar con: python3 -c "import bcrypt;print(bcrypt.hashpw(b'TU_PASSWORD', bcrypt.gensalt(rounds=12)).decode())"
MS_ADMIN_PASSWORD_HASH=
# Generar con: python3 -c "import secrets;print(secrets.token_hex(32))"
MS_SECRET_KEY=
MS_WORKSPACE=/var/www/codeaerospace_contenido
MS_RUNNER_SOCKET=/run/manimstudio/runner.sock
MS_COOKIE_SECURE=1
# Cuota total de disco para render_jobs/ en MB (crear jobs por encima -> 507)
MS_MAX_STORAGE_MB=2048

# ── Asistente IA (opcional; sin esto la app funciona y la UI de IA se oculta) ──
# Service account de GCP con acceso a Vertex AI. NUNCA commitear el JSON.
# MS_GCP_KEY_PATH=/var/www/codeaerospace_contenido/studio/backend/gcp-key.json
# Solo modelos Gemini 2.5 y solo us-central1.
MS_GCP_LOCATION=us-central1
MS_GEMINI_MODEL_FAST=gemini-2.5-flash
MS_GEMINI_MODEL_DEEP=gemini-2.5-pro
# Peticiones IA por minuto por sesion
MS_AI_RATE_LIMIT=10
