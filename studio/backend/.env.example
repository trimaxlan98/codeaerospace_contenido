# ManimStudio — copiar a .env y completar. NUNCA commitear el .env real.
MS_ADMIN_USER=admin
# Generar con: python3 -c "import bcrypt;print(bcrypt.hashpw(b'TU_PASSWORD', bcrypt.gensalt(rounds=12)).decode())"
MS_ADMIN_PASSWORD_HASH=
# Generar con: python3 -c "import secrets;print(secrets.token_hex(32))"
MS_SECRET_KEY=
MS_WORKSPACE=/var/www/codeaerospace_contenido
MS_RUNNER_SOCKET=/run/manimstudio/runner.sock
MS_COOKIE_SECURE=1
